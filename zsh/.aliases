function alias_value() {
  (( $+aliases[$1] )) && echo $aliases[$1]
}

function try_alias_value() {
  alias_value "$1" || echo "$1"
}

alias c="clear"
alias x="exit"
alias r="source ~/.zshrc"
alias ls="colorls"

alias cd -="cd -"
alias md='mkdir -p'
alias rd='rmdir'

alias home="cd ~/"

alias edit-zsh="nvim ~/.zshrc"
alias vim="nvim" #set default VIM to Neovim

# List directory contents
alias ll='ls -lh'
alias lla='ls -lAh'

alias tkss="tmux kill-session -t"
alias tmd="tmux detach"
alias stx="tmux source ~/.tmux.conf"

# Persistent Claude session — attach if exists, create if not
cs() {
  tmux attach -t claude 2>/dev/null || tmux new-session -s claude
}


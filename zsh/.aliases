# Homelab Mount (sshfs)
homelab-mount() {
  if mountpoint -q ~/homelab-mnt; then
    fusermount -u ~/homelab-mnt && echo "Unmounted"
  else
    sshfs mikekey@192.168.1.3:/mnt/storage ~/homelab-mnt && echo "Mounted"
  fi
}

# Ollama Stuff
alias ollamaStart="ollama serve > /dev/null 2>&1 &"
alias ollamaStop="pkill ollama"
alias ollamaStatus="pgrep -fl ollama || echo 'Ollama is not running'"
alias ollamaRestart="pkill ollama; sleep 1; ollama serve > /dev/null 2>&1 &"

# Local Qwen (Qwopus) 27B Dense (Vulkan llama-server)
q27Up() {
  if curl -s http://127.0.0.1:8082/health > /dev/null 2>&1; then
    echo "Qwopus already running"
    return 0
  fi
  LD_LIBRARY_PATH=~/Experiments/llama.cpp/build-vulkan/bin \
  nohup ~/Experiments/llama.cpp/build-vulkan/bin/llama-server \
    -m ~/Experiments/AI/models/Qwopus3.5-27B-v3-Q6_K.gguf \
    -ngl 99 -ts 1/1 -c 131072 --port 8082 \
    > /tmp/Qwopus-server.log 2>&1 &
  echo "Starting Qwopus-27B... (log: /tmp/Qwopus-server.log)"
  sleep 3
  if curl -s http://127.0.0.1:8082/health > /dev/null 2>&1; then
    echo "Qwopus-27B is up → http://localhost:8082"
  else
    echo "Not healthy yet — check /tmp/Qwopus-server.log"
  fi
}

q27Down() {
  pkill -f "llama-server.*8082" && echo "Qwopus stopped" || echo "Qwopus not running"
}

alias q27Status="curl -s http://127.0.0.1:8082/health 2>/dev/null && echo '' || echo 'Qwopus not running'"
alias q27Log="tail -f /tmp/Qwopus-server.log"


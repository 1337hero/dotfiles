# Scaffold Dev
alias scaffold="cd ~/Builds/scaffold"
alias scaffoldDaemon="cd ~/Builds/scaffold/daemon"
alias scaffoldApp="cd ~/Builds/scaffold/app"
alias scaffoldLogs="journalctl --user -u scaffold-daemon.service -f"
alias scaffoldStatus='systemctl --user --no-pager status scaffold-daemon.service scaffold-signal-cli.service'
alias scaffoldRestart='systemctl --user restart scaffold-signal-cli.service scaffold-daemon.service'
alias scaffoldStop='systemctl --user stop scaffold-daemon.service scaffold-signal-cli.service'
alias scaffoldStart='systemctl --user start scaffold-signal-cli.service scaffold-daemon.service'

scaffoldRebuild() {
  if ! (cd ~/Builds/scaffold/daemon && go build -o bin/scaffold-daemon .); then
    echo "Build failed"
    return 1
  fi

  if ! systemctl --user restart scaffold-daemon.service; then
    echo "Restart failed"
    return 1
  fi

  # Give systemd a moment so fast crash loops are detectable.
  sleep 1
  local state
  state=$(systemctl --user show scaffold-daemon.service -p ActiveState -p SubState --value | paste -sd '/')
  if [[ "$state" == "active/running" ]]; then
    echo "Rebuilt + restarted (active/running)"
    return 0
  fi

  echo "Rebuilt, but daemon is not healthy ($state)"
  journalctl --user -u scaffold-daemon.service -n 20 --no-pager
  return 1
}

scaffoldBuildApp() {
  (cd ~/Builds/scaffold/app && bun run build) && echo "Frontend built" || echo "Build failed"
}

scaffoldTest() {
  (cd ~/Builds/scaffold/daemon && go test ./...)
}

scaffoldEnv() {
  ${EDITOR:-nvim} ~/Builds/scaffold/daemon/.env
}

ytDL() {
  local mode="mp3"
  local title=""
  local url=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --mp3)
        mode="mp3"
        shift
        ;;
      --video|--vid)
        mode="video"
        shift
        ;;
      --t|--title)
        if [[ -z "$2" ]]; then
          echo "ytDL: missing title after $1"
          return 1
        fi
        title="$2"
        shift 2
        ;;
      -h|--help)
        cat <<'EOF'
Usage:
  ytDL --mp3 [--t "Custom Title"] "URL"
  ytDL --video [--t "Custom Title"] "URL"

Notes:
  --mp3 is the default mode if you omit it.
  --video downloads the best available video/audio capped at 1080p.
  If you omit --t/--title, yt-dlp uses the site's video title.
EOF
        return 0
        ;;
      -*)
        echo "ytDL: unknown option $1"
        return 1
        ;;
      *)
        if [[ -n "$url" ]]; then
          echo "ytDL: only one URL is supported"
          return 1
        fi
        url="$1"
        shift
        ;;
    esac
  done

  if [[ -z "$url" ]]; then
    echo 'ytDL: missing URL'
    echo 'Try: ytDL --mp3 --t "Title" "https://..."'
    return 1
  fi

  local output_template="%(title)s.%(ext)s"
  if [[ -n "$title" ]]; then
    output_template="${title}.%(ext)s"
  fi

  if [[ "$mode" == "mp3" ]]; then
    yt-dlp \
      -x \
      --audio-format mp3 \
      --audio-quality 0 \
      --write-thumbnail \
      -o "$output_template" \
      "$url"
    return
  fi

  yt-dlp \
    -f "bv*+ba/b" \
    -S "res:1080" \
    --merge-output-format mp4 \
    --write-thumbnail \
    --convert-thumbnails jpg \
    -o "$output_template" \
    "$url"
}

alias ytDLv='ytDL --video'

#  ytDL --mp3 --t "Stormlight Archive Ambience - Words of Radiance" "https://www.youtube.com/watch?v=kS92aTNisCw"
#  ytDL --mp3 "https://www.youtube.com/watch?v=kS92aTNisCw"
#  ytDL --video "https://www.youtube.com/watch?v=kS92aTNisCw"
#  ytDLv --t "Custom Title" "https://www.youtube.com/watch?v=kS92aTNisCw"

#  --mp3 is the default, so ytDL "url" also works. If you omit --t, it uses yt-dlp’s title-based output template. The MP3 path keeps --w
#  rite-thumbnail, and the video path uses -f "bv*+ba/b" -S "res:1080" so yt-dlp picks the best video/audio combination while targeting
#  no more than 1080p when available. --write-thumbnail writes the thumbnail file to disk. (github.com
#  (https://github.com/yt-dlp/yt-dlp/blob/master/README.md?utm_source=openai))

# Open Zed in the current directory
zed() {
    echo "Opening the current directory in Zed."
    command zeditor .
}
